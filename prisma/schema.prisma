generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  manager
  staff
  groomer
}

enum AppointmentStatus {
  scheduled
  confirmed
  checked_in
  in_progress
  completed
  cancelled
  no_show
}

enum AppointmentSource {
  whatsapp
  phone
  walk_in
  online
}

enum Species {
  perro
  gato
  otro
}

enum PetSize {
  pequeno
  mediano
  grande
  gigante
}

enum ReminderStatus {
  drafted
  sent
  skipped
}

model Branch {
  id           String        @id @default(cuid())
  name         String
  address      String
  phone        String
  active       Boolean       @default(true)
  appointments Appointment[]
  userBranches UserBranch[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  phone               String
  role                Role
  active              Boolean       @default(true)
  appointments        Appointment[] @relation("GroomerAppointments")
  createdAppointments Appointment[] @relation("CreatedAppointments")
  userBranches        UserBranch[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model UserBranch {
  userId   String
  branchId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  phone         String
  whatsappOptIn Boolean  @default(false)
  notes         String   @default("")
  pets          Pet[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Pet {
  id            String        @id @default(cuid())
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name          String
  species       Species
  breed         String
  size          PetSize
  birthdate     DateTime?
  ageEstimate   String?
  healthNotes   String        @default("")
  behaviorNotes String        @default("")
  appointments  Appointment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Service {
  id                       String               @id @default(cuid())
  name                     String
  estimatedDurationMinutes Int
  active                   Boolean              @default(true)
  appointments             AppointmentService[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
}

model Appointment {
  id              String               @id @default(cuid())
  branchId        String
  branch          Branch               @relation(fields: [branchId], references: [id])
  petId           String
  pet             Pet                  @relation(fields: [petId], references: [id])
  groomerId       String
  groomer         User                 @relation("GroomerAppointments", fields: [groomerId], references: [id])
  createdById     String
  createdBy       User                 @relation("CreatedAppointments", fields: [createdById], references: [id])
  scheduledStart  DateTime
  scheduledEnd    DateTime
  status          AppointmentStatus    @default(scheduled)
  source          AppointmentSource
  notes           String               @default("")
  services        AppointmentService[]
  groomingRecord  GroomingRecord?
  reminderLogs    ReminderLog[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([branchId, scheduledStart])
  @@index([groomerId, scheduledStart, scheduledEnd])
  @@index([petId, scheduledStart])
}

model AppointmentService {
  appointmentId String
  serviceId     String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@id([appointmentId, serviceId])
}

model GroomingRecord {
  id             String      @id @default(cuid())
  appointmentId  String      @unique
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actualStart    DateTime?
  actualEnd      DateTime?
  groomerNotes   String      @default("")
  outcome        String      @default("")
  beforePhotoUrl String?
  afterPhotoUrl  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model ReminderLog {
  id              String         @id @default(cuid())
  appointmentId   String
  appointment     Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  channel         String         @default("whatsapp")
  messageTemplate String
  manualStatus    ReminderStatus @default(drafted)
  timestamp       DateTime       @default(now())
}
