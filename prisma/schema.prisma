generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  manager
  staff
  groomer
}

enum AppointmentStatus {
  scheduled
  confirmed
  checked_in
  in_progress
  completed
  cancelled
  no_show
}

enum AppointmentSource {
  whatsapp
  phone
  walk_in
  online
}

enum Species {
  perro
  gato
  otro
}

enum PetSize {
  pequeno
  mediano
  grande
  gigante
}

enum ReminderStatus {
  drafted
  sent
  skipped
}

model Branch {
  id           Int           @id @default(autoincrement())
  name         String
  address      String
  phone        String
  active       Boolean       @default(true)
  appointments Appointment[]
  userBranches UserBranch[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model User {
  id                  Int           @id @default(autoincrement())
  name                String
  email               String        @unique
  phone               String
  role                Role
  active              Boolean       @default(true)
  appointments        Appointment[] @relation("GroomerAppointments")
  createdAppointments Appointment[] @relation("CreatedAppointments")
  userBranches        UserBranch[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model UserBranch {
  userId   Int
  branchId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String
  whatsappOptIn Boolean  @default(false)
  notes         String   @default("")
  pets          Pet[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Pet {
  id            Int           @id @default(autoincrement())
  customerId    Int
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name          String
  species       Species
  breed         String
  size            PetSize
  profilePhotoUrl String?
  birthdate       DateTime?
  ageEstimate     String?
  healthNotes     String        @default("")
  behaviorNotes   String        @default("")
  appointments    Appointment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Service {
  id                       Int                  @id @default(autoincrement())
  name                     String
  estimatedDurationMinutes Int
  active                   Boolean              @default(true)
  appointments             AppointmentService[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
}

model Appointment {
  id              Int                  @id @default(autoincrement())
  branchId        Int
  branch          Branch               @relation(fields: [branchId], references: [id])
  petId           Int
  pet             Pet                  @relation(fields: [petId], references: [id])
  groomerId       Int
  groomer         User                 @relation("GroomerAppointments", fields: [groomerId], references: [id])
  createdById     Int
  createdBy       User                 @relation("CreatedAppointments", fields: [createdById], references: [id])
  scheduledStart  DateTime
  scheduledEnd    DateTime
  status          AppointmentStatus    @default(scheduled)
  source          AppointmentSource
  notes           String               @default("")
  services        AppointmentService[]
  groomingRecord  GroomingRecord?
  reminderLogs    ReminderLog[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([branchId, scheduledStart])
  @@index([groomerId, scheduledStart, scheduledEnd])
  @@index([petId, scheduledStart])
}

model AppointmentService {
  appointmentId Int
  serviceId     Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@id([appointmentId, serviceId])
}

model GroomingRecord {
  id                      Int         @id @default(autoincrement())
  appointmentId           Int         @unique
  appointment             Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actualStart             DateTime?
  actualEnd               DateTime?
  groomerNotes            String      @default("")
  outcome                 String      @default("")
  intakeSignatureName     String?
  intakeSignedAt          DateTime?
  completionSignatureName String?
  completionSignedAt      DateTime?
  satisfactionNotes       String      @default("")
  beforePhotoUrl          String?
  afterPhotoUrl           String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model ReminderLog {
  id              Int            @id @default(autoincrement())
  appointmentId   Int
  appointment     Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  channel         String         @default("whatsapp")
  messageTemplate String
  manualStatus    ReminderStatus @default(drafted)
  timestamp       DateTime       @default(now())
}
